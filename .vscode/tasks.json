{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "[Release] Configure",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "cmake --preset armhf-Release"
      ],
      "problemMatcher": []
    },
    {
      "label": "[Release] Build",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "cmake --build --preset armhf-Release"
      ],
      "problemMatcher": []
    },
    {
      "label": "[Release] Deploy",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "rsync -avz --delete ${workspaceFolder}/build_arm32/armhf-Release/bin/ root@192.168.5.75:/root/srv_rel/exams/ && rsync -avz --delete ${workspaceFolder}/build_arm32/armhf-Release/lib/ root@192.168.5.75:/root/srv_rel/lib/"
      ],
      "problemMatcher": []
    },
    {
      "label": "[Release] Build Release & Deploy",
      "dependsOn": [
        "[Release] Configure",
        "[Release] Build",
        "[Release] Deploy"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "[Debug] Clean Dir",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "rm -rf '${workspaceFolder}/build_arm32/armhf-Debug' '${workspaceFolder}/install/armhf-Debug'"
      ],
      "problemMatcher": []
    },
    {
      "label": "[Debug] Configure",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "cmake --preset armhf-Debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "[Debug] Build",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "cmake --build --preset armhf-Debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "[Debug] Deploy",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "rsync -avz --delete ${workspaceFolder}/build_arm32/armhf-Debug/bin/ root@192.168.5.75:/root/srv/exams/ && rsync -avz --delete ${workspaceFolder}/build_arm32/armhf-Debug/lib/ root@192.168.5.75:/root/srv/lib/"
      ],
      "problemMatcher": []
    },
    {
      "label": "[Debug] Deploy test dir",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "rsync -avz --delete ${workspaceFolder}/build_arm32/armhf-Debug/bin/ root@192.168.5.75:/root/srv_tests/exams/ && rsync -avz --delete ${workspaceFolder}/build_arm32/armhf-Debug/lib/ root@192.168.5.75:/root/srv_tests/lib/"
      ],
      "problemMatcher": []
    },
    {
      "label": "[Debug] Start gdbserver",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "ssh root@192.168.5.75 \"set -e; export LD_LIBRARY_PATH=/root/srv/exams:$LD_LIBRARY_PATH; killall extsrv 2>/dev/null || true; chmod +x /root/srv/exams/extsrv; exec gdbserver :1234 /root/srv/exams/extsrv\""
      ],
      "problemMatcher": []
    },
    {
      "label": "[Debug] Start gdbserver test dir",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "ssh root@192.168.5.75 \"set -e; export LD_LIBRARY_PATH=/root/srv_tests/exams:$LD_LIBRARY_PATH; killall extsrv 2>/dev/null || true; chmod +x /root/srv_tests/exams/extsrv; exec gdbserver :1234 /root/srv_tests/exams/extsrv\""
      ],
      "problemMatcher": []
    },
    {
      "label": "[Debug] Start gdbserver & Exit",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "ssh root@192.168.5.75 \"set -e; export LD_LIBRARY_PATH=/root/srv/exams:$LD_LIBRARY_PATH; killall extsrv 2>/dev/null || true; chmod +x /root/srv/exams/extsrv; nohup gdbserver :1234 /root/srv/exams/extsrv >/root/srv/log/extsrv.log 2>&1 & sleep 1\""
      ],
      "problemMatcher": []
    },
    {
      "label": "[Debug] Configure & Build",
      "dependsOn": [
        "[Debug] Configure",
        "[Debug] Build"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "[Debug] Build & Deploy",
      "dependsOn": [
        "[Debug] Configure",
        "[Debug] Build",
        "[Debug] Deploy"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "[Debug] Build & Deploy test dir",
      "dependsOn": [
        "[Debug] Configure",
        "[Debug] Build",
        "[Debug] Deploy test dir"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "[Debug] Clean Rebuild & Deploy",
      "dependsOn": [
        "Clean Dir",
        "Build & Deploy"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "[Debug] Build, Deploy & Start",
      "dependsOn": [
        "Build & Deploy",
        "Start gdbserver"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "[Debug] Build, Deploy, Start & Exit",
      "dependsOn": [
        "Build & Deploy",
        "Start gdbserver & Exit"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    }
  ]
}